# OpenAI 兼容接口（DeepSeek 等）
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# 可选：同默认服务商下的模型预设（/model 可切换）
# OPENAI_MODEL_PRESETS=deepseek-chat,deepseek-reasoner

# 多服务商模型配置（/model 可切换不同 API 地址与密钥）
# MODEL_PROFILES=deepseek,openai
# 一个 profile 可配多个模型（逗号分隔）；多模型时用 profile/别名 切换
# MODEL_PROFILE_deepseek=deepseek-chat,deepseek-reasoner|https://api.deepseek.com
# MODEL_PROFILE_deepseek=chat:deepseek-chat,reasoner:deepseek-reasoner|https://api.deepseek.com
# MODEL_PROFILE_openai=gpt-4o,gpt-4o-mini|https://api.openai.com/v1|sk-your-openai-key

# DeepSeek 思考模式：使用 deepseek-reasoner 或开启 thinking 时设为 true
# 留空则模型名含 reasoner 时自动开启
# THINKING_MODE=false

# Agent 配置
AGENT_NAME=ff-agent
# 单个目录（兼容旧配置）
SKILLS_DIR=./skills

# 多个目录，逗号或冒号分隔；会与 SKILLS_DIR 合并，后出现的目录同名 skill 会覆盖前者
# SKILLS_DIRS=./skills,~/.cursor/skills

# Role 配置（/role 命令切换身份，共享聊天历史）
ROLES_DIR=./roles
DEFAULT_ROLE=default
MEMORY_PATH=./data/memory.json
MAX_MEMORY_ITEMS=50

# 对话历史（退出后重开可恢复 TUI 聊天记录与 LLM 上下文）
CHAT_HISTORY_PATH=./data/chat_history.json
SESSIONS_DIR=./data/sessions
MAX_CHAT_MESSAGES=200
PERSIST_CHAT_HISTORY=true
# TUI 与微信共用同一会话（默认 true）；设为 false 则每个微信联系人独立会话
SHARED_CHAT_SESSION=true
# 启动 TUI 时自动在后台拉起微信 Gateway（需 CHANNELS=wechat）
AUTO_START_GATEWAY=true

# 规划与执行：工作区根目录、是否允许 shell、计划步数上限
WORKSPACE_DIR=.
ALLOW_SHELL=true
MAX_PLAN_STEPS=12
MAX_DISCUSS_ROUNDS=10
MAX_ASSIGN_TURNS=24
MAX_ASSIGN_TOOL_STEPS=40
COMMAND_TIMEOUT=60

# 单轮对话最多工具调用步数上限（防止工具调用死循环）
MAX_CHAT_STEPS=40

# 启动 TUI 时自动在后台拉起 Web 界面（与 TUI 共享会话历史）
AUTO_START_WEB=true
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Web 界面（仅 python main.py --web 时使用相同配置）
# 启用微信扫码模式（默认）：
CHANNELS=wechat
# ilink = 扫码登录（同 OpenClaw）；official = 微信公众号 Webhook
WECHAT_MODE=ilink
CHANNEL_GATEWAY_HOST=0.0.0.0
CHANNEL_GATEWAY_PORT=8787
WECHAT_ILINK_CREDENTIALS=./data/channels/wechat_ilink.json
WECHAT_BOT_AGENT=ff-agent/0.1.0
WECHAT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WECHAT_MEDIA_DIR=./data/channels/wechat/media
# WECHAT_ALLOWED_USER_IDS=user1@im.wechat

# 微信公众号模式（WECHAT_MODE=official 时使用）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=
WECHAT_WEBHOOK_PATH=/channels/wechat/webhook
# WECHAT_ALLOWED_OPENIDS=oXXXX
